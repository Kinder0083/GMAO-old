# ==========================================
# CONFIGURATION FRONTEND GMAO IRIS
# ==========================================

# URL BACKEND
# -----------
# ⚠️ IMPORTANT : Configuration pour l'accès à distance
#
# Option 1 (RECOMMANDÉ) : Détection automatique
# Laisser vide pour que l'application détecte automatiquement l'URL
# Fonctionne en local ET à distance (IP publique ou nom de domaine)
REACT_APP_BACKEND_URL=
#
# Option 2 : URL explicite (si la détection automatique ne fonctionne pas)
# Exemples :
# - IP locale : REACT_APP_BACKEND_URL=http://192.168.1.124
# - IP publique : REACT_APP_BACKEND_URL=http://82.66.41.98
# - Nom de domaine : REACT_APP_BACKEND_URL=http://mon-domaine.com
#
# ⚠️ ATTENTION :
# Si vous utilisez une IP locale (192.168.x.x), l'application ne sera
# accessible QUE depuis votre réseau local, pas depuis internet !

# Configuration WebSocket (pour le mode développement)
WDS_SOCKET_PORT=443

# Options de développement
REACT_APP_ENABLE_VISUAL_EDITS=false
ENABLE_HEALTH_CHECK=false
